# SolarTracer MQTT Publisher Configuration
# Copy this file to .env and fill in your values.

# RS-485 serial port. Use "auto" to detect the Exar adapter on each boot/replug
# (stable symlink: /dev/solartracer-rs485 when the udev rule is installed).
SERIAL_DEVICE=auto

# MQTT Broker connection
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=solartracer

# Base topic prefix for all published values.
# Example: solartracer/battery_voltage
MQTT_BASE_TOPIC=solartracer

# Home Assistant MQTT Discovery prefix.
# Set to "homeassistant" to enable auto-discovery of sensors.
# Set to empty to disable discovery (just publish raw values).
MQTT_HA_DISCOVERY_PREFIX=homeassistant

# Optional: Device name shown in Home Assistant
DEVICE_NAME=Solar Tracer
DEVICE_ID=solartracer_pi
MANUFACTURER=EPEVER
MODEL=Tracer BN Series

# How often to read the charger and publish MQTT updates (seconds)
PUBLISH_INTERVAL=60

# Voltage trend sampling between full reads (seconds). Defaults to PUBLISH_INTERVAL.
# Set lower than PUBLISH_INTERVAL only if you need finer time-remaining estimates.
# VOLTAGE_SAMPLE_INTERVAL=60

# Holding-register config refresh interval (seconds). Charger settings change rarely.
# CONFIG_REFRESH_SEC=300

# Poll interval when the charger is unreachable (seconds). Avoids hammering a dead bus.
# UNREACHABLE_POLL_INTERVAL=120

# Small pause between Modbus transactions (seconds). Helps on shared RS-485 buses.
# MODBUS_INTER_READ_DELAY_SEC=0.05

# Optional: override ./var for local history files
# SOLARTRACER_DATA_DIR=/var/lib/solartracer

# For testing without an MQTT broker:
# DRY_RUN=1 python3 publish_mqtt.py
# This will print what would be published and skip the broker connection.