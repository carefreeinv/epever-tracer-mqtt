# SolarTracer MQTT Publisher Configuration
# Copy this file to .env and fill in your values.

# Serial device for the RS-485 USB adapter (Exar XR21B1411 usually appears as /dev/ttyACM0)
SERIAL_DEVICE=/dev/ttyACM0

# MQTT Broker connection
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=solartracer

# Base topic prefix for all published values.
# Example: solartracer/battery_voltage
MQTT_BASE_TOPIC=solartracer

# Home Assistant MQTT Discovery prefix.
# Set to "homeassistant" to enable auto-discovery of sensors.
# Set to empty to disable discovery (just publish raw values).
MQTT_HA_DISCOVERY_PREFIX=homeassistant

# Optional: Device name shown in Home Assistant
DEVICE_NAME=Solar Tracer
DEVICE_ID=solartracer_pi
MANUFACTURER=EPEVER
MODEL=Tracer BN Series

# How often to read the charger and publish MQTT updates (seconds)
PUBLISH_INTERVAL=30

# For testing without an MQTT broker:
# DRY_RUN=1 python3 publish_mqtt.py
# This will print what would be published and skip the broker connection.